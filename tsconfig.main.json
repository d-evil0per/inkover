{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    // outDir = "dist", rootDir = "src" → src/main/index.ts emits to dist/main/index.js,
    // src/preload/index.ts → dist/preload/index.js, src/shared/* → dist/shared/*.
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*"]
}
