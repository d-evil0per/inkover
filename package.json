{
  "name": "inkover",
  "productName": "InkOver",
  "version": "0.1.0",
  "description": "InkOver — a cross-platform screen annotation tool with multi-monitor overlays, presentation aids, and screen recording.",
  "main": "dist/main/index.js",
  "author": "InkOver",
  "license": "MIT",
  "homepage": "https://github.com/d-evil0per/inkover",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-evil0per/inkover.git"
  },
  "bugs": {
    "url": "https://github.com/d-evil0per/inkover/issues"
  },
  "keywords": [
    "annotation",
    "screen-annotation",
    "presentation",
    "electron",
    "whiteboard",
    "screen-recording"
  ],
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "site:dev": "vite --config website/vite.config.ts",
    "site:build": "vite build --config website/vite.config.ts",
    "site:preview": "vite preview --config website/vite.config.ts",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "npm run build && electron .",
    "package": "npm run build && node scripts/package-host.mjs",
    "package:mac": "npm run build && electron-builder --config electron-builder.config.cjs --mac",
    "package:win": "npm run build && cross-env INKOVER_WINDOWS_LOCAL_BUILD=1 electron-builder --config electron-builder.config.cjs --win",
    "package:win:installer": "npm run package:win:elevated",
    "package:win:release": "npm run build && electron-builder --config electron-builder.config.cjs --win",
    "package:win:elevated": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/package-win-elevated.ps1",
    "package:linux": "npm run build && electron-builder --config electron-builder.config.cjs --linux",
    "lint": "eslint src scripts",
    "smoke:e2e": "node scripts/smoke-e2e.mjs",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.26.0",
    "globals": "^16.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.3.3",
    "vite": "^6.4.2",
    "wait-on": "^7.2.0"
  }
}
